{
  "name": "MosaicAI",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/mosaic",

  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/sshd:1": {}
  },

  "forwardPorts": [8000, 8081, 5432, 6379],
  "portsAttributes": {
    "8000": { "label": "FastAPI Backend" },
    "8081": { "label": "Expo Dev Server" },
    "5432": { "label": "PostgreSQL" },
    "6379": { "label": "Redis" }
  },

  "postCreateCommand": "pip install pre-commit && pre-commit install && cd backend && pip install -r requirements.txt && cd ../mobile && npm install",
  "postStartCommand": "cd backend && alembic upgrade head",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "eamodio.gitlens",
        "github.copilot",
        "ms-python.debugpy",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg",
        "humao.rest-client"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.terminal.activateEnvInCurrentTerminal": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.formatOnSave": true
        },
        "[typescript][typescriptreact]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode",
          "editor.formatOnSave": true
        }
      }
    }
  },

  "containerEnv": {
    "DATABASE_URL": "postgresql://mosaic:mosaic@db:5432/mosaic",
    "REDIS_URL": "redis://redis:6379/0"
  },

  "remoteEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
    "OPENAI_API_KEY": "${localEnv:OPENAI_API_KEY}",
    "GNEWS_API_KEY": "${localEnv:GNEWS_API_KEY}",
    "SUPABASE_URL": "${localEnv:SUPABASE_URL}",
    "SUPABASE_KEY": "${localEnv:SUPABASE_KEY}"
  }
}
